{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@api/*": ["./src/api/*"],
      "@store/*": ["./src/store/*"],
      "@components/*": ["./src/components/*"],
      "@pages/*": ["./src/pages/*"],
      "@schemas/*": ["./src/schemas/*"],
      "@hooks/*": ["./src/hooks/*"],
      "@utils/*": ["./src/utils/*"],
      "@constants/*": ["./src/constants/*"],
      "@context/*": ["./src/context/*"],
      "@router/*": ["./src/router/*"],
      "@assets/*": ["./src/assets/*"]
    },
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "module": "ESNext",
    "checkJs": false,
    "ignoreDeprecations": "6.0"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
